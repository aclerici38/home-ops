{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    ':automergeBranch',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':separatePatchReleases',
    ':skipStatusChecks',
    ':timezone(America/Los_Angeles)',
    'github>aclerici38/home-ops//.github/renovate/autoMerge.json5',
    'github>aclerici38/home-ops//.github/renovate/customManagers.json5',
    'github>aclerici38/home-ops//.github/renovate/grafanaDashboards.json5',
    'github>aclerici38/home-ops//.github/renovate/groups.json5',
    'github>aclerici38/home-ops//.github/renovate/labels.json5',
    'github>aclerici38/home-ops//.github/renovate/packageRules.json5',
    'github>aclerici38/home-ops//.github/renovate/semanticCommits.json5',
  ],
  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  ignorePaths: [
    '**/*.sops.*',
    '.archive/**',
  ],
  flux: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml$/',
    ],
  },
  "helm-values": {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml$/',
    ],
  },
  nix: {
    enabled: true,
    lockFileMaintenance: {
      enabled: true,
      // Run every cycle except Mon 04:00–04:59 (the automerge window)
      schedule: [
        "* * * * 0,2-6", // Sun, Tue–Sat all day
        "* 0-3 * * 1",   // Mon 00:00–03:59
        "* 5-23 * * 1",  // Mon 05:00–23:59
      ],
    },
  },
  registryAliases: {
    "mirror.gcr.io": "docker.io"
  },
}
