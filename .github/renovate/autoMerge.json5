{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: ["Auto-merge GitHub Actions for minor and patch"],
      matchManagers: ["github-actions"],
      matchDatasources: ["github-tags"],
      automerge: true,
      automergeType: "branch",
      matchUpdateTypes: ["minor", "patch"],
    },
    {
      description: ["Auto-merge specific apps' minor versions"],
      automerge: true,
      automergeType: "branch",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: [
        "**/airconnect",
        "**/bazarr",
        "**/calibre-web-automated-book-downloader",
        "**/cloudflare-ddns",
        "**/code-server",
        "**/collabora/code",
        "**/coredns",
        "**/crowdsec-web-ui",
        "**/flaresolverr",
        "**/grafana",
        "**/it-tools",
        "**/k8s-sidecar",
        "**/kube-prometheus-stack",
        "**/loki",
        "**/meilisearch",
        "**/omni-tools",
        "**/open-webui",
        "**/prowlarr",
        "**/prometheus-smartctl-exporter",
        "**/radarr",
        "**/renovate",
        "**/searxng",
        "**/smartmontools",
        "**/sonarr",
        "**/talhelper",
        "**/tuppr",
        "**/zfs-scrubber",
      ],
      matchUpdateTypes: ["minor", "patch", "digest"],
    },
    {
      description: ["Auto-merge specific apps' major versions"],
      automerge: true,
      automergeType: "branch",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["**/firefox", "**/http-https-echo"],
      matchUpdateTypes: ["major", "minor", "patch", "digest"],
    },
    {
      description: ["Auto-merge k8s-versioned-schemas"],
      automerge: true,
      automergeType: "branch",
      matchDatasources: ["github-tags"],
      matchPackageNames: ["aclerici38/k8s-versioned-schemas"],
      matchUpdateTypes: ["major", "minor", "patch"],
    },
  ],
}
