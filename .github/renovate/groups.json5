{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Omada-Controller Group",
      groupName: "Omada-Controller",
      matchPackagePatterns: ["omada-controller", "omada-controller-helm"],
      matchDatasources: ["docker"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Kgateway Group",
      groupName: "Kgateway",
      matchPackagePatterns: ["kgateway-dev", "^kgateway$"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Opencloud Group",
      groupName: "Opencloud",
      matchPackagePatterns: ["opencloudeu"],
      matchDatasources: ["docker"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Flux Operator Group",
      groupName: "Flux Operator",
      matchPackagePatterns: [
        "flux-operator",
        "flux-instance",
        "flux-operator-manifests",
        "controlplaneio-fluxcd/charts",
        "^flux$",
      ],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 4,
    },
    {
      description: "Intel-Device-Plugins Group",
      groupName: "Intel Device Plugins",
      matchPackagePatterns: ["intel-device-plugins"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Talos Group",
      groupName: "Talos",
      matchPackagePatterns: ["siderolabs/talosctl", "siderolabs/installer"],
      matchDatasources: ["docker"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Immich Group",
      groupName: "Immich",
      matchPackagePatterns: ["immich-app"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "External Secrets Group",
      groupName: "External Secrets",
      matchPackagePatterns: ["external-secrets"],
      matchDatasources: ["docker", "github-releases", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Cilium group",
      groupName: "Cilium",
      matchPackagePatterns: ["cilium"],
      matchDatasources: ["docker", "github-releases", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Coredns group",
      groupName: "Coredns",
      matchPackagePatterns: ["coredns"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "1Pass group",
      groupName: "1Pass",
      matchPackagePatterns: ["1password"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Rook-Ceph group",
      groupName: "Rook-Ceph",
      matchPackagePatterns: ["rook"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "CNPG-Barman-Cloud group",
      groupName: "CNPG-Barman-Cloud",
      matchPackagePatterns: [
        "plugin-barman-cloud",
        "plugin-barman-cloud-sidecar",
      ],
      matchDatasources: ["docker", "github-releases", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 3,
    },
    {
      description: "CNPG Postgres Containers group",
      groupName: "CNPG-postgres-containers",
      matchPackagePatterns: ["cloudnative-pg/postgresql"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Streamystats group",
      groupName: "Streamystats",
      matchPackagePatterns: [
        "streamystats-v2-nextjs",
        "streamystats-v2-job-server",
      ],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Vectorchord Group",
      groupName: "Vectorchord",
      matchPackagePatterns: ["VectorChord", "vchord-scratch"],
      matchDatasources: ["docker", "github-releases"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "bjw-s-labs group",
      groupName: "bjw-s-labs",
      matchPackagePatterns: ["bjw-s-labs"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Cert-Manager group",
      groupName: "Cert-Manager",
      matchPackagePatterns: ["cert-manager"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "External-DNS group",
      groupName: "External-DNS",
      matchPackagePatterns: ["external-dns"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Pocket-ID group",
      groupName: "Pocket-ID",
      matchPackagePatterns: ["pocket-id"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Silence-Operator group",
      groupName: "Silence-Operator",
      matchPackagePatterns: ["silence-operator"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "CloudNative-PG group",
      groupName: "CloudNative-PG",
      matchPackagePatterns: ["^cloudnative-pg$"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Gateway-API group",
      groupName: "Gateway-API",
      matchPackagePatterns: ["gateway-api"],
      matchDatasources: ["github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Grafana-Operator group",
      groupName: "Grafana-Operator",
      matchPackagePatterns: ["grafana-operator"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Kube-Prometheus-Stack group",
      groupName: "Kube-Prometheus-Stack",
      matchPackagePatterns: ["kube-prometheus-stack"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "OpenEBS group",
      groupName: "OpenEBS",
      matchPackagePatterns: ["openebs"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Snapshot-Controller group",
      groupName: "Snapshot-Controller",
      matchPackagePatterns: ["snapshot-controller"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Dragonfly-Operator group",
      groupName: "Dragonfly-Operator",
      matchPackagePatterns: ["dragonfly-operator"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Multus group",
      groupName: "Multus",
      matchPackagePatterns: ["multus"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Node-Feature-Discovery group",
      groupName: "Node-Feature-Discovery",
      matchPackagePatterns: ["node-feature-discovery"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "KEDA group",
      groupName: "KEDA",
      matchPackagePatterns: ["keda"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Tuppr group",
      groupName: "Tuppr",
      matchPackagePatterns: ["tuppr"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Volsync group",
      groupName: "Volsync",
      matchPackagePatterns: ["perfectra1n-volsync", "perfectra1n/volsync"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
    {
      description: "Renovate-Operator group",
      groupName: "Renovate-Operator",
      matchPackagePatterns: ["renovate-operator"],
      matchDatasources: ["docker", "github-tags"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
    },
  ],
}
