# Vars here consumed by talhelper, the shell via nix, and the
# flux/meta secretGenerator (Secret/cluster-secrets in flux-system).

# Versions
# renovate: datasource=github-releases depName=siderolabs/talos
TALOS_VERSION=v1.13.5
# renovate: datasource=docker depName=ghcr.io/siderolabs/kubelet
KUBE_VERSION=v1.36.2

# Misc
SECRET_DOMAIN=clerici.tech
TZ=America/Los_Angeles
EXTERNAL_WILDCARD=*.clerici.tech

# Cluster
CLUSTER_NAME=dormammu
CLUSTER_ENDPOINT_VIP=10.0.30.250
CLUSTER_ENDPOINT_URL=https://10.0.30.250:6443
# Git path this cluster's FluxInstance syncs (see flux-instance hr.yaml)
FLUX_PATH=kubernetes/flux/home

# Pod / service CIDRs
CLUSTER_POD_CIDR=172.16.0.0/16
CLUSTER_POD_CIDR_V6=fdf6:d3fd:1748:1000::/56
CLUSTER_SVC_CIDR=172.17.0.0/16
CLUSTER_SVC_CIDR_V6=fdf6:d3fd:1748:2000::/112
CLUSTER_SVC_GATEWAY=172.17.0.1

# Node network
NODE_V4_SUBNET=10.0.30.0/24
NODE_V6_SUBNET=fdf6:d3fd:1748:0030::/64
NODE_GATEWAY=10.0.30.1
# OPNsense ULA for BGP
NODE_GATEWAY_V6=fdf6:d3fd:1748:0030::1
NODE_NAMESERVER=10.0.30.1

# Node v4 and v6 ULA IPs
BONDS_IP=10.0.30.25
BONDS_V6=fdf6:d3fd:1748:0030::25
CAIN_IP=10.0.30.18
CAIN_V6=fdf6:d3fd:1748:0030::18
POSEY_IP=10.0.30.28
POSEY_V6=fdf6:d3fd:1748:0030::28
BELT_IP=10.0.30.9
BELT_V6=fdf6:d3fd:1748:0030::9

# Service IPs
COREDNS_CLUSTER_IP=172.17.0.10
BLOCKY_CLUSTER_IP=172.17.0.11
K8S_GATEWAY_CLUSTER_IP=172.17.0.13

# Cilium LB IPs
OMADA_LB_IP=10.38.55.10
SAMBA_LB_IP=10.38.55.11
BLOCKY_LB_IP=10.38.55.25
BLOCKY_LB_IPV6=fdf6:d3fd:1748:0055::25
NFS_LB_IP=10.38.55.30
D3SAVANT_LB_IP=10.38.55.38
CROWDSEC_LB_IP=10.38.55.50
CROWDSEC_AGENT_LB_IP=10.38.55.51
KGATEWAY_INTERNAL_LB_IP=10.38.55.90
KGATEWAY_EXTERNAL_LB_IP=10.38.55.91
