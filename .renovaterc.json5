{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>home-operations/renovate-presets#2.1.0',
    ':semanticCommits',
    ':timezone(America/Los_Angeles)',
    'github>aclerici38/home-ops//renovate/autoMerge.json5',
    'github>aclerici38/home-ops//renovate/customManagers.json5',
    'github>aclerici38/home-ops//renovate/grafanaDashboards.json5',
    'github>aclerici38/home-ops//renovate/groups.json5',
    'github>aclerici38/home-ops//renovate/labels.json5',
    'github>aclerici38/home-ops//renovate/packageRules.json5',
  ],
  assignees: ['aclerici38'],
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],
  ignorePaths: [
    '**/*.sops.*'
  ],
  nix: {
    enabled: true,
    lockFileMaintenance: {
      enabled: true,
    },
  },
}
