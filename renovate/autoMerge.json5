{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  platformAutomerge: false,
  // Override the preset bundle's :automergeBranch back to PR-style automerge.
  automergeType: "pr",
  assignAutomerge: false,
  packageRules: [
    {
      description: ["Auto-merge GitHub Actions for minor and patch"],
      matchManagers: ["github-actions"],
      matchDatasources: ["github-tags"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
    },
    {
      description: ["Auto-merge specific apps' minor versions"],
      automerge: true,
      matchDatasources: ["docker", "helm", "github-tags", "github-releases"],
      matchPackageNames: [
        "**/airconnect",
        "**/bazarr",
        "**/chromium",
        "**/cloudflare-ddns",
        "**/code-server",
        "**/collabora/code",
        "**/crowdsec-web-ui",
        "**/flaresolverr",
        //"**/flate",
        "**/grafana",
        "**/it-tools",
        "**/k8s-sidecar",
        "**/kube-prometheus-stack",
        "**/meilisearch",
        "**/omni-tools",
        "**/open-webui",
        "**/prowlarr",
        "**/prometheus-smartctl-exporter",
        "**/radarr",
        "**/renovate",
        "**/searxng",
        "**/smartmontools",
        "**/sonarr",
        "**/talhelper",
        "**/tuppr",
        "**/zfs-scrubber",
      ],
      matchUpdateTypes: ["minor", "patch", "digest"],
    },
    {
      description: ["Auto-merge specific apps' major versions"],
      automerge: true,
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["**/firefox", "**/http-https-echo"],
      matchUpdateTypes: ["major", "minor", "patch", "digest"],
    },
    {
      description: ["Branch auto-merge digest-only updates from home-operations org"],
      automerge: true,
      matchPackageNames: ["ghcr.io/home-operations/**"],
      matchUpdateTypes: ["digest"],
    },
    {
      description: ["Auto-merge k8s-versioned-schemas"],
      automerge: true,
      matchDatasources: ["github-tags"],
      matchPackageNames: ["aclerici38/k8s-versioned-schemas"],
      matchUpdateTypes: ["major", "minor", "patch"],
    },
    {
      description: ["Auto-merge mise updates by default"],
      matchManagers: ["mise"],
      automerge: true,
      matchUpdateTypes: ["major", "minor", "patch", "digest"],
    },
    {
      description: ["Exclude specific mise tools from auto-merge"],
      matchManagers: ["mise"],
      matchDepNames: [
        "kubectl",
        "github:cloudnative-pg/cloudnative-pg",
      ],
      automerge: false,
    },
  ],
}
