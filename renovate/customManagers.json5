{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      description: ["Track oci-container images in raphael nix (tag@digest)"],
      customType: "regex",
      fileMatch: ["(^|/)raphael/.*\\.nix$"],
      matchStrings: [
        "image\\s*=\\s*\"(?<depName>[^:\"]+):(?<currentValue>[^@\"]+)@(?<currentDigest>sha256:[a-f0-9]+)\"",
      ],
      datasourceTemplate: "docker",
      autoReplaceStringTemplate: "image = \"{{{depName}}}:{{{newValue}}}@{{{newDigest}}}\"",
    },
    {
      // The built-in `nix` manager only refreshes flake.lock *within* the pinned
      // branch (nix flake update); it never bumps nixos-26.05 -> nixos-26.11.
      // nixpkgs tags each stable release as a plain `YY.MM` git tag, so track
      // those and rewrite the branch ref. NB: this bumps flake.nix only — run
      // `nix flake update nixpkgs` when applying so flake.lock follows.
      description: ["Track NixOS stable release channel (raphael flake)"],
      customType: "regex",
      fileMatch: ["(^|/)raphael/flake\\.nix$"],
      matchStrings: ["github:NixOS/nixpkgs/nixos-(?<currentValue>\\d+\\.\\d+)"],
      datasourceTemplate: "github-tags",
      depNameTemplate: "NixOS/nixpkgs",
      versioningTemplate: "loose",
      // stable YY.MM tags only — excludes -pre / -beta prereleases
      allowedVersions: "/^\\d+\\.\\d+$/",
      autoReplaceStringTemplate: "github:NixOS/nixpkgs/nixos-{{{newValue}}}",
    },
    {
      description: ["Process various other dependencies"],
      customType: "regex",
      fileMatch: [".*"], // process regex from everywhere
      matchStrings: [
        // Example: `k3s_release_version: "v1.27.3+k3s1"` (general regex matcher)
        'datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\n.*?"(?<currentValue>.*)"\n',
        "(?m)datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?[\\s\\S]*?^\\s*\\S+\\s*[:=]\\s*(?<currentValue>\\S+)",
        // Example: `- https://github.com/rancher/system-upgrade-controller/releases/download/v0.11.0/crd.yaml` (e.g. kustomization.yaml lists)
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( versioning=(?<versioning>\\S+))?\n.*?-\\s(.*?)\/(?<currentValue>[^/]+)\/[^/]+\n",
        // for: apiVersion=helm.cattle.io/v1 kind=HelmChart
        "datasource=(?<datasource>\\S+)\n.*?repo: (?<registryUrl>\\S+)\n.*?chart: (?<depName>\\S+)\n.*?version: (?<currentValue>\\S+)\n",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      versioningTemplate: "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
    },
    {
      customType: "regex",
      description: "Process Grafana CRD version field",
      fileMatch: ["grafana-instance/.*\\.ya?ml$"],
      matchStrings: [
        "version:\\s*(?<depName>[^:]+):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)",
      ],
      datasourceTemplate: "docker",
      autoReplaceStringTemplate: "version: {{{depName}}}:{{{newValue}}}@{{{newDigest}}}",
    },
    {
      customType: "regex",
      description: "Process yaml-language-server schema versions from GitHub tags URLs",
      fileMatch: ["\\.ya?ml$"],
      matchStrings: [
        "\\$schema=https://raw\\.githubusercontent\\.com/(?<depName>[^/]+/[^/]+)/refs/tags/(?<currentValue>[^/]+)/",
      ],
      datasourceTemplate: "github-tags",
    },
    {
      customType: "regex",
      description: "Process yannh/kubernetes-json-schema versions",
      fileMatch: ["\\.ya?ml$"],
      matchStrings: [
        "\\$schema=https://raw\\.githubusercontent\\.com/yannh/kubernetes-json-schema/master/(?<currentValue>v[^-]+)-standalone-strict/",
      ],
      datasourceTemplate: "docker",
      depNameTemplate: "ghcr.io/siderolabs/kubelet",
    },
    {
      customType: "regex",
      fileMatch: ["\\.ya?ml$"],
      matchStrings: [
        "k8s-versioned-schemas\\.pages\\.dev/(?<depName>[^/]+)/(?<currentValue>[^/]+)/",
        "\\?values=(?<depName>[^/]+)/(?<currentValue>[^\\s]+)",
        "aclerici38/k8s-versioned-schemas/crds/(?<depName>[^/]+)/(?<currentValue>[^/\\s'\"]+)",
      ],
      datasourceTemplate: "github-tags",
      packageNameTemplate: "aclerici38/k8s-versioned-schemas",
      extractVersionTemplate: "^{{{depName}}}/(?<version>.*)$",
    },
  ],
}
